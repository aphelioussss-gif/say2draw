# ===================================
# Say2Draw LLM Configuration
# ===================================
# Supports any OpenAI-compatible multimodal API.
# Primary model: mimo-v2.5

# ---- MiMo (default) ----
OPENAI_API_KEY=sk-your-mimo-key
OPENAI_BASE_URL=https://api.xiaomimimo.com/v1
OPENAI_MODEL=mimo-v2.5

# ---- OpenAI (alternative) ----
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ---- Custom (any OpenAI-compatible multimodal) ----
# OPENAI_API_KEY=sk-your-key
# OPENAI_BASE_URL=https://your-api.com/v1
# OPENAI_MODEL=your-model-name

# Server port (default: 3001)
PORT=3001
